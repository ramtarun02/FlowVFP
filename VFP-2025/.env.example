# FlowVFP – Frontend Environment Variables
# ==========================================
# Copy this file to .env.local for local development.
# .env.local is git-ignored by default with Vite.
#
# NEVER commit real credentials in .env files.

# ── API / WebSocket ───────────────────────────────────────────────────────────

# Base URL for the Flask API server (leave blank to use auto-detection)
VITE_API_URL=http://127.0.0.1:5000

# WebSocket URL (usually the same as the API)
VITE_WS_URL=http://127.0.0.1:5000

# Production override (only used when VITE_API_URL is not set)
# VITE_PROD_API_URL=https://vfp-solver-gngfaahkh2fkbbhh.uksouth-01.azurewebsites.net

# ── Deployment ────────────────────────────────────────────────────────────────

# Base path used by Vite when deploying to GitHub Pages (sub-path)
# VITE_BASE_PATH=/VFP-2025
